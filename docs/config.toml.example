# GraphSAST configuration file
#
# Place this file at either:
#   ~/.graphsast/config.toml          (user-global, applies to all projects)
#   <project>/.graphsast/config.toml  (project-local, overrides user-global)
#
# Environment variables override config files:
#   GRAPHSAST_LLM__MODEL=qwen2.5:14b graphsast scan .
#
# CLI flags override everything:
#   graphsast scan . --llm-model qwen2.5:14b

# ── LLM backend ───────────────────────────────────────────────────────────────
[llm]
# backend  = "ollama"                # "ollama" (default), "claude", "openai", or "bedrock"
# model   = "llama3.1"               # Model name — auto-upgraded per backend when left as default:
#                                    #   ollama  → "llama3.1"
#                                    #   claude  → "claude-opus-4-6"
#                                    #   openai  → "gpt-4o"
#                                    #   bedrock → "anthropic.claude-3-5-sonnet-20241022-v2:0"
# base_url = "http://localhost:11434" # Ollama server URL (ollama backend only)
# timeout  = 300.0                   # Per-request timeout in seconds
# temperature = 0.1                  # Sampling temperature (lower = more deterministic)
# num_ctx  = 8192                    # Context window size (tokens, ollama only)
# health_check_timeout = 5.0         # Timeout for the Ollama reachability probe
# max_entry_points = 0               # Phase 1A entry points to analyse (0 = all)
# phase1a_max_turns = 8              # Max LLM turns per entry point in Phase 1A
# phase1b_max_turns_l2 = 5           # Max turns for Phase 1B layer-2 validation
# phase1b_max_turns_l3 = 3           # Max turns for Phase 1B layer-3 micro-task

# Anthropic (claude backend)
# claude_api_key = ""                # Anthropic API key (default: $ANTHROPIC_API_KEY)

# OpenAI (openai backend)
# openai_api_key = ""                # OpenAI API key (default: $OPENAI_API_KEY)

# AWS Bedrock (bedrock backend)
# bedrock_region       = "us-east-1" # AWS region
# bedrock_access_key   = ""          # AWS access key ID (default: $AWS_ACCESS_KEY_ID)
# bedrock_secret_key   = ""          # AWS secret access key (default: $AWS_SECRET_ACCESS_KEY)
# bedrock_session_token = ""         # Temporary session token (optional)

# ── Vulnerability DB ──────────────────────────────────────────────────────────
[vulndb]
# sources = ["builtin", "custom", "semgrep", "wstg", "lang_sigs"]
# semgrep_rules_repo = "https://github.com/semgrep/semgrep-rules"
# semgrep_cache_dir  = "~/.graphsast/cache/semgrep-rules"  # set to override default

# ── Semgrep runner ────────────────────────────────────────────────────────────
[semgrep]
# rules_per_file  = 200   # Rules bundled per temp file
# timeout         = 300   # Semgrep CLI execution timeout (seconds)
# message_max_len = 500   # Truncate semgrep rule messages to this length

# ── Analysis ──────────────────────────────────────────────────────────────────
[analysis]
# taint_max_depth  = 10   # Max BFS hops for source→sink path finding
# line_bucket_size = 5    # Lines window for deduplicating co-located findings

# ── Output ────────────────────────────────────────────────────────────────────
[output]
# format = "markdown"   # Default report format: markdown | json | sarif

# ── Paths ─────────────────────────────────────────────────────────────────────
[paths]
# db_subdir = ".graphsast"   # Subdirectory name under scan target for graph.db / vulns.db
